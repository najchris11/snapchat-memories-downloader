# ── Gradle ───────────────────────────────────────────────────────────────────
.gradle/
build/
**/build/
local.properties

# ── Kotlin ───────────────────────────────────────────────────────────────────
.kotlin/
*.class

# ── Android ──────────────────────────────────────────────────────────────────
*.apk
*.ap_
*.aab

# ── Python ───────────────────────────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so

# ── App data (user files, not source) ────────────────────────────────────────
snapchat_memories/
downloaded_files.json
download_errors.json
metadata.json
memories_history.html

# ── Bundled runtime (generated in CI) ────────────────────────────────────────
runtime/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── Android signing ───────────────────────────────────────────────────────────
*.jks
keystore.properties

# ── Test data ─────────────────────────────────────────────────────────────────
test-run/
test-data/

# ── Development artifacts (planning docs, investigation scripts) ───────────────
plan*.md
investigate_*.py

# ── Linux bundled binaries (large; downloaded by scripts/prepare-runtime-linux.sh) ──
composeApp/src/desktopMain/resources/bin/linux-x64/*.zip
composeApp/src/desktopMain/resources/bin/linux-x64/*.tar.xz
composeApp/src/desktopMain/resources/bin/linux-x64/*.tar.gz

# ── iOS scaffold (desktop-only for v1.0) ──────────────────────────────────────
iosApp/

# ── Release artifacts (also covered by build/) ────────────────────────────────
*.dmg
*.msi
*.deb

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
